# Same string in Meta Developer → WhatsApp → Configuration → Webhook → Verify token
WHATSAPP_VERIFY_TOKEN=choose_a_long_random_secret_and_match_meta_dashboard

# WhatsApp Cloud API: Meta Developer → WhatsApp → API Setup → Temporary access token (or System User token)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v21.0

# OpenAI API credentials used for auto-reply on every inbound WhatsApp text message
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local/devcontainer Postgres connection
DATABASE_URL=postgresql://postgres:postgres@db:5432/jandz-ai
