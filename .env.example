# Runtime environment: "dev" prefixes outbound bot replies with [dev]; "prod" does not
ENV="dev"

# Telegram Bot API: create via @BotFather; webhook URL should point to /webhook/telegram
TELEGRAM_BOT_TOKEN="123456:REPLACE_ME_TELEGRAM_BOT_TOKEN"
TELEGRAM_WEBHOOK_SECRET="REPLACE_ME_TELEGRAM_WEBHOOK_SECRET"
# Public HTTPS origin for opportunity detail pages linked from Telegram (no trailing slash or path).
# Example: https://xxxx.ngrok-free.app  →  links like https://xxxx.ngrok-free.app/opportunities/123
PUBLIC_BASE_URL="https://example.ngrok-free.app"

# OpenAI API credentials used for auto-reply on every inbound Telegram text message
OPENAI_API_KEY="sk-REPLACE_ME_OPENAI_API_KEY"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_AUDIO_MODEL="gpt-4o-mini-transcribe"

# CoreSignal REST API key (sent as apikey header to api.coresignal.com)
CORESIGNAL_API_KEY="REPLACE_ME_CORESIGNAL_API_KEY"

# Admin dashboard login (/)
ADMIN_LOGIN="admin"
ADMIN_PASSWORD="change_me"
ADMIN_SESSION_SECRET="replace_with_a_long_random_secret"

# Local/devcontainer Postgres connection
DATABASE_URL="postgresql://postgres:postgres@db:5432/jandz-ai"
